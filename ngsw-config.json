{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/icons/**",
          "/**/*.{svg,cur,jpg,jpeg,png,apng,webp,avif,gif,otf,ttf,woff,woff2}"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "supabase-api",
      "urls": ["https://uwjajsukgdulyvjjeazd.supabase.co/rest/v1/processing_queue**", "https://uwjajsukgdulyvjjeazd.supabase.co/rest/v1/processing_logs**"],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "5m",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "supabase-static",
      "urls": ["https://uwjajsukgdulyvjjeazd.supabase.co/rest/v1/suppliers**", "https://uwjajsukgdulyvjjeazd.supabase.co/rest/v1/app_config**", "https://uwjajsukgdulyvjjeazd.supabase.co/rest/v1/training_examples**"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "24h",
        "timeout": "5s",
        "strategy": "performance"
      }
    }
  ]
}
